# ============================================================
# NutriMate — environment template
# Copy to .env at the repo root (or per-app) and fill in values.
# ============================================================

# ---------- Shared ----------
NODE_ENV=development
LOG_LEVEL=info

# ---------- API (apps/api) ----------
API_PORT=4000
API_BASE_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/nutrimate

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# ML service (internal)
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT_MS=2000

# Nutrition APIs
SPOONACULAR_API_KEY=
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Optional cache / rate limiting
REDIS_URL=

# ---------- ML service (services/ml) ----------
ML_PORT=8000
ML_MODEL_DIR=./models
ML_KNN_K=8

# ---------- Web (apps/web) ----------
VITE_API_BASE_URL=http://localhost:4000/api/v1
