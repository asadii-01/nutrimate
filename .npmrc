# Keep pnpm's content-addressable store on the same NTFS partition as the
# project so that pnpm can hardlink files into node_modules instead of
# copying them across filesystems. Dramatically speeds up installs on this
# host. (See: README.md "Prerequisites" notes.)
store-dir=./.pnpm-store

# Hoist common dev tooling so editors / Phase-4 Vite plugins resolve them.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*types*

# Don't strict-fail on engines mismatch (we run Node 24 but pin "engines: >=20").
engine-strict=false
