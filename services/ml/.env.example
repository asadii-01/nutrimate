# NutriMate ML service — runtime config. Copy to .env; all values are optional.

# HTTP bind
ML_HOST=0.0.0.0
ML_PORT=8000

# Model artifact directory (default: services/ml/models)
# ML_MODELS_DIR=./models

# KNN neighbours (TRD §6.2)
ML_KNN_K=5

# ±tolerance band when composing a plan against the kcal target
ML_KCAL_TOLERANCE=0.10

# Log level: DEBUG | INFO | WARNING | ERROR
ML_LOG_LEVEL=INFO
