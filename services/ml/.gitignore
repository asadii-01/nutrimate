# Python env — venv + pip cache live on the NTFS partition (see HANDOFF.md)
.venv/
.pip-cache/

# Datasets — the cleaned CSV is reproducible via pipelines/preprocess.py;
# data/raw/ holds the third-party Kaggle source (licence varies — keep untracked)
data/*.csv
data/*.parquet
data/raw/

# Model metadata is regenerated by the training scripts
models/*.json
